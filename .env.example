# Server
PORT=8080
ENV=development

# PostgreSQL
DATABASE_URL=postgres://statuskeet:statuskeet@localhost:5432/statuskeet?sslmode=disable
# Vercel Marketplace Postgres integrations may provide one of these instead:
# POSTGRES_URL=postgres://...
# POSTGRES_PRISMA_URL=postgres://...
# Supabase Postgres can also be used here. For serverless deployments, prefer the pooler URL.

# Redis
REDIS_URL=redis://localhost:6379

# App session auth
JWT_SECRET=change-me-to-a-random-secret-in-production

# Auth provider
# AUTH_MODE=legacy
# AUTH_MODE=supabase

# Supabase Auth
# SUPABASE_URL=https://db.mzpyvaaxrlzvlweihpff.supabase.co
# SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Legacy env name fallbacks also work:
# SUPABASE_ANON_KEY=eyJ...
# SUPABASE_SECRET_KEY=sb_secret_...

# Optional
# CRON_SECRET=change-me-to-secure-vercel-cron
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
